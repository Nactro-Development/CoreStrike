<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CoreStrike.DashBord.DashBord"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CoreStrike.DashBord"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">


    <ScrollViewer>
        <Grid  Padding="20">

            <!-- ROWS -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Top cards -->
                <RowDefinition Height="*"/>
                <!-- Bottom section -->
            </Grid.RowDefinitions>

            <!-- ================= TOP 3 CARDS ================= -->
            <Grid Grid.Row="0" ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- CPU CARD -->
                <Border Grid.Column="0" CornerRadius="12"  Background="{ThemeResource LayerFillColorDefaultBrush }" Padding="16" >
                    <StackPanel Spacing="3">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Foreground="Gray" Glyph="&#xE950;" FontSize="16"/>
                            <TextBlock Foreground="Gray" Text="CPU" FontWeight="SemiBold"/>
                        </StackPanel>

                        <TextBlock Text="{x:Bind CpuName, Mode=OneWay}" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap"/>


                        <Border Height="150" 
                                
          
CornerRadius="4" 
Background="#1A000000" 
Margin="0,12,0,12">


                            <lvc:CartesianChart 
    Background="Transparent" 
                            HorizontalAlignment="Stretch"
    x:Name="CpuChart"

    Series="{x:Bind CpuSeries}"
    XAxes="{x:Bind XAxes}"
    YAxes="{x:Bind YAxes}"/>
                        </Border>


                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>

                            </Grid.ColumnDefinitions>








                            <Border Grid.Column="0" BorderBrush="{ThemeResource SystemAccentColor}" BorderThickness="1.5" HorizontalAlignment="Left" Width="100" CornerRadius="5" Background="{ThemeResource LayerFillColorDefaultBrush}">

                                <StackPanel Margin="10" Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center" >
                                    <Viewbox Margin="5" Width="40" Height="40">
                                        <Path x:Name="FanIcon"
Data="M243.78,318.4c-16.78,20.61-41.43,32.81-68.09,32.93l-.17-168.23c-2.31,21.98-12.28,42.1-28.63,57.13-32.04,29.45-79.93,31.12-113.8,3.68C12.62,227.34.06,202.58,0,175.68l168.22-.17c-21.43-2.25-41.12-11.82-56.01-27.44-32.18-33.75-32.52-85.78-.6-119.86C128.06,10.67,150.96.05,175.65,0l.17,167.5c2.56-21.57,12.3-41.22,28.21-56.03,33.97-31.6,85.75-31.48,119.46.49,17.33,16.43,27.8,39.16,27.84,63.68l-167.51.17c22.13,2.65,42.2,12.75,57.14,29.43,28.7,32.03,30.25,79.46,2.82,113.16Z"
Fill="{ThemeResource SystemAccentColor}"
RenderTransformOrigin="0.5,0.5">
                                            <Path.RenderTransform>
                                                <RotateTransform x:Name="FanRotate"/>
                                            </Path.RenderTransform>
                                        </Path>
                                    </Viewbox>


                                    <TextBlock Text="{x:Bind CpufanText, Mode=OneWay}" FontSize="15" Foreground="#94A3B8"/>
                                    <TextBlock Text="{x:Bind CpuTemperature, Mode=OneWay}" FontWeight="Bold" FontSize="15" Foreground="{ThemeResource SystemAccentColor}"/>
                                </StackPanel>





                            </Border>


                            <StackPanel VerticalAlignment="Center" Grid.Column="2" >
                                <TextBlock Text="{x:Bind CpuSpeed, Mode=OneWay}" FontSize="28" FontWeight="Bold" />

                                <TextBlock Text="{x:Bind CpuDisplayText, Mode=OneWay}" Foreground="#94A3B8"/>
                                <StackPanel  Spacing="20" Orientation="Horizontal" >
                                    <TextBlock Foreground="#94A3B8" Text="{x:Bind CpuCoreSvi2Voltage, Mode=OneWay}" />
                                    <TextBlock Foreground="#94A3B8" Text="{x:Bind CpuBusSpeed,  Mode=OneWay}" />
                                </StackPanel>
                                <TextBlock Foreground="{ThemeResource SystemAccentColor}" FontWeight="Bold" Text="{x:Bind CpuPackagePower,    Mode=OneWay}" />


                            </StackPanel>



                        </Grid>


                        <!-- Converter නැතිව — style දෙකක් -->
                        <Button x:Name="StressTestButton"
        Content="{x:Bind StressButtonText, Mode=OneWay}"
        Click="StressTestButton_Click"
        Margin="0,8,0,0"
     
        HorizontalAlignment="Stretch"/>


                    </StackPanel>
                </Border>

                <!-- GPU CARD -->
                <Border Grid.Column="1" CornerRadius="12" Background="{ThemeResource LayerFillColorDefaultBrush }" Padding="16" >
                    <StackPanel Spacing="3">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Foreground="Gray" Glyph="&#xE7F4;" FontSize="16"/>
                            <TextBlock Foreground="Gray" Text="GPU" FontWeight="SemiBold"/>
                        </StackPanel>



                        <ComboBox 
                        x:Name="GpuSelectionComboBox"
                        ItemsSource="{x:Bind AvailableGpus, Mode=OneWay}"
                        SelectedIndex="{x:Bind SelectedGpuIndex, Mode=TwoWay}"
                        PlaceholderText="Select GPU..."
                        Margin="0,12,0,12"/>



                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>

                            </Grid.ColumnDefinitions>


                            <StackPanel Grid.Column="0" >
                                <StackPanel >


                                    <TextBlock Text="{x:Bind GpuDisplayText, Mode=OneWay}" Foreground="#94A3B8"/>


                                    <Border  Height="80" 


CornerRadius="4" 
Background="#1A000000" 
Margin="0,12,0,12">


                                        <lvc:CartesianChart 
    Background="Transparent" 
    HorizontalAlignment="Stretch"
    x:Name="Gpu3DChart"
    Series="{x:Bind Gpu3DSeries}"
    XAxes="{x:Bind Gpu3DXAxes}"
    YAxes="{x:Bind Gpu3DYAxes}"/>
                                    </Border>

                                </StackPanel>


                                <StackPanel >


                                    <TextBlock Text="{x:Bind Gpu3DCopyDisplayText, Mode=OneWay}" Foreground="#94A3B8"/>


                                    <Border  Height="80" 


CornerRadius="4" 
Background="#1A000000" 
Margin="0,12,0,12">


                                        <lvc:CartesianChart 
    Background="Transparent" 
    HorizontalAlignment="Stretch"
    x:Name="Gpu3DCopyChart"
    Series="{x:Bind Gpu3DCopySeries}"
    XAxes="{x:Bind Gpu3DCopyXAxes}"
    YAxes="{x:Bind Gpu3DCopyYAxes}"/>
                                    </Border>

                                </StackPanel>

                            </StackPanel>



                            <StackPanel Grid.Column="2">

                                <StackPanel  >

                                    <TextBlock  Text="{x:Bind Gpu3DVEDisplayText, Mode=OneWay}" Foreground="#94A3B8"/>

                                    <Border   Height="80" 


CornerRadius="4" 
Background="#1A000000" 
Margin="0,12,0,12">


                                        <lvc:CartesianChart 
    Background="Transparent" 
    HorizontalAlignment="Stretch"
    x:Name="Gpu3DVEChart"
    Series="{x:Bind Gpu3DVESeries}"
    XAxes="{x:Bind Gpu3DVEXAxes}"
    YAxes="{x:Bind Gpu3DVEYAxes}"/>
                                    </Border>

                                </StackPanel>
                                <StackPanel  >

                                    <TextBlock Text="{x:Bind Gpu3DVDDisplayText, Mode=OneWay}" Foreground="#94A3B8"/>

                                    <Border  Height="80" 


CornerRadius="4" 
Background="#1A000000" 
Margin="0,12,0,12">


                                        <lvc:CartesianChart 
    Background="Transparent" 
    HorizontalAlignment="Stretch"
    x:Name="Gpu3DVDChart"
    Series="{x:Bind Gpu3DVDSeries}"
    XAxes="{x:Bind Gpu3DVDXAxes}"
    YAxes="{x:Bind Gpu3DVDYAxes}"/>
                                    </Border>

                                </StackPanel>
                            </StackPanel>



                        </Grid>


                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>

                            </Grid.ColumnDefinitions>




                            <Border Grid.Column="0" BorderBrush="{ThemeResource SystemAccentColor}" BorderThickness="1.5" HorizontalAlignment="Left" Width="100" CornerRadius="5" Background="{ThemeResource LayerFillColorDefaultBrush}">

                                <StackPanel Margin="10" Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center" >
                                    <Viewbox Margin="5" Width="40" Height="40">
                                        <Path x:Name="FanIconGPU"
Data="M243.78,318.4c-16.78,20.61-41.43,32.81-68.09,32.93l-.17-168.23c-2.31,21.98-12.28,42.1-28.63,57.13-32.04,29.45-79.93,31.12-113.8,3.68C12.62,227.34.06,202.58,0,175.68l168.22-.17c-21.43-2.25-41.12-11.82-56.01-27.44-32.18-33.75-32.52-85.78-.6-119.86C128.06,10.67,150.96.05,175.65,0l.17,167.5c2.56-21.57,12.3-41.22,28.21-56.03,33.97-31.6,85.75-31.48,119.46.49,17.33,16.43,27.8,39.16,27.84,63.68l-167.51.17c22.13,2.65,42.2,12.75,57.14,29.43,28.7,32.03,30.25,79.46,2.82,113.16Z"
Fill="{ThemeResource SystemAccentColor}"
RenderTransformOrigin="0.5,0.5">
                                            <Path.RenderTransform>
                                                <RotateTransform x:Name="FanRotateGPU"/>
                                            </Path.RenderTransform>
                                        </Path>
                                    </Viewbox>


                                    <TextBlock Text="{x:Bind FanDisplayText, Mode=OneWay}" FontSize="15" Foreground="#94A3B8"/>
                                    <TextBlock Text="{x:Bind GpuTemperature, Mode=OneWay}" FontWeight="Bold" FontSize="15" Foreground="{ThemeResource SystemAccentColor}"/>
                                </StackPanel>





                            </Border>






                            <StackPanel Grid.Column="2" >
                                <TextBlock Text="{x:Bind GpuClock, Mode=OneWay}" FontSize="28" FontWeight="Bold" />
                                <TextBlock Text="{x:Bind GPUCoreUsageText, Mode=OneWay}" Foreground="#94A3B8"/>
                                <TextBlock Text="{x:Bind GpuMemoryUsed, Mode=OneWay}" Foreground="#94A3B8"/>

                                <TextBlock Text="{x:Bind GPUPowerText, Mode=OneWay}" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}"/>

                            </StackPanel>
                        </Grid>


                    </StackPanel>
                </Border>




                <Grid Grid.Column="2" >
                    <!-- ROWS -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <!-- Top cards -->
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="*"/>
                        <!-- Bottom section -->
                    </Grid.RowDefinitions>
                    <!-- RAM CARD -->
                    <Border Grid.Row="0" CornerRadius="12" Background="{ThemeResource LayerFillColorDefaultBrush }" Padding="16" >
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Foreground="Gray" Glyph="&#xEEA0;" FontSize="16"/>
                                <TextBlock Foreground="Gray" Text="MEMORY" FontWeight="SemiBold"/>
                            </StackPanel>

                            <TextBlock Text="Physical Memeory" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <TextBlock Text="{x:Bind MemoryUsageText, Mode=OneWay}" Foreground="#94A3B8"/>
                            <Border Height="80" 
                                
          
CornerRadius="4" 
Background="#1A000000" 
Margin="0,12,0,12">


                                <lvc:CartesianChart 
    Background="Transparent" 
    HorizontalAlignment="Stretch"
    x:Name="RAMChart"
    Series="{x:Bind RAMSeries}"
    XAxes="{x:Bind RAMXAxes}"
    YAxes="{x:Bind RAMYAxes}"/>

                            </Border>

                            <TextBlock Text="{x:Bind MemoryTotal, Mode=OneWay}" FontSize="28" FontWeight="Bold" />

                            <TextBlock Text="{x:Bind MemoryUsed, Mode=OneWay}" Foreground="#94A3B8"/>








                        </StackPanel>
                    </Border>


                    <Border Grid.Row="2"   CornerRadius="12" Background="{ThemeResource LayerFillColorDefaultBrush }" Padding="16" >

                        <StackPanel>

                            <TextBlock  Text="Virtual Memeory" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <TextBlock Text="{x:Bind VirtualUsage, Mode=OneWay}" Foreground="#94A3B8"/>
                            <Border Height="80" 
                                
          
CornerRadius="4" 
Background="#1A000000" 
Margin="0,12,0,12">


                                <lvc:CartesianChart 
    Background="Transparent" 
    HorizontalAlignment="Stretch"
    x:Name="VRAMChart"
    Series="{x:Bind VRAMSeries}"
    XAxes="{x:Bind VRAMXAxes}"
    YAxes="{x:Bind VRAMYAxes}"/>

                            </Border>



                            <TextBlock Text="{x:Bind VirtualTotal, Mode=OneWay}" FontSize="28" FontWeight="Bold" />

                            <TextBlock Text="{x:Bind VirtualUsed, Mode=OneWay}" Foreground="#94A3B8"/>



                        </StackPanel>

                    </Border>


                </Grid>





            </Grid>

            <!-- ================= BOTTOM SECTION ================= -->
            <Grid Grid.Row="1" Margin="0,20,0,0" ColumnSpacing="20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <!-- Big storage -->
                    <ColumnDefinition Width="1*"/>
                    <!-- Right side -->
                </Grid.ColumnDefinitions>

                <!-- LARGE STORAGE CARD -->
                <Border Grid.Column="0" CornerRadius="12"
        Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="20">
                    <StackPanel Spacing="10">

                        <!-- Header -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Foreground="Gray" Glyph="&#xEDA2;" FontSize="16"/>
                            <TextBlock Foreground="Gray" Text="STORAGE" FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- Drive selector ComboBox -->
                        <ComboBox x:Name="DriveSelectionComboBox"
                  ItemsSource="{x:Bind AvailableDrives, Mode=OneWay}"
                  SelectedIndex="{x:Bind SelectedDriveIndex, Mode=TwoWay}"
                  PlaceholderText="Select Drive..."
                  HorizontalAlignment="Stretch"
                  Margin="0,4,0,8"/>

                        <!-- Drive name + type badge -->
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal" Spacing="8">

                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal" Spacing="8" >
                                <FontIcon VerticalAlignment="Center" Foreground="Gray" Glyph="&#xEDA2;" FontSize="35"/>
                                <TextBlock VerticalAlignment="Center" Text="{x:Bind DriveName, Mode=OneWay}"
FontSize="18" FontWeight="SemiBold"
TextWrapping="Wrap"/>
                            </StackPanel>



                            <Border Height="20" Background="{ThemeResource SystemAccentColor}"
                    CornerRadius="4" Padding="6,2">
                                <TextBlock VerticalAlignment="Center" Text="{x:Bind DriveType, Mode=OneWay}"
                           FontSize="11" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </StackPanel>

                        <!-- Windows-style Progress Bar -->
                        <StackPanel Spacing="8" Margin="0,12,0,0">
                            <ProgressBar Value="{x:Bind DriveUsagePercent, Mode=OneWay}"
                                     Maximum="100"
                                     Height="20"
                                     CornerRadius="4"
                                     Foreground="{ThemeResource SystemAccentColor}">

                                <ProgressBar.Resources>
                                    <Style TargetType="ProgressBar">
                                        <Setter Property="MinHeight" Value="15"/>
                                    </Style>
                                </ProgressBar.Resources>

                            </ProgressBar>


                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                       Text="{x:Bind DriveUsedSpace, Mode=OneWay}"
                                       FontSize="12"
                                       Foreground="#94A3B8"
                                       TextAlignment="Left"/>

                                <TextBlock Grid.Column="2"
                                       Text="{x:Bind DriveFreeSpace, Mode=OneWay}"
                                       FontSize="12"
                                       Foreground="#94A3B8"
                                       TextAlignment="Right"/>
                            </Grid>
                        </StackPanel>

                        <!-- ── Two-column stats grid ── -->
                        <Grid ColumnSpacing="20" RowSpacing="10" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Total capacity -->
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Total Capacity" Foreground="#94A3B8" FontSize="11"/>
                                <TextBlock Text="{x:Bind DriveTotalSpace, Mode=OneWay}"
                           FontSize="24" FontWeight="Bold"/>
                            </StackPanel>

                            <!-- Usage % -->
                            <StackPanel Grid.Row="0" Grid.Column="1">
                                <TextBlock Text="Usage" Foreground="#94A3B8" FontSize="11"/>
                                <TextBlock Text="{x:Bind DriveUsageText, Mode=OneWay}"
                           FontSize="24" FontWeight="Bold"
                           Foreground="{ThemeResource SystemAccentColor}"/>
                            </StackPanel>

                            <!-- Used / Free -->
                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <TextBlock Text="{x:Bind DriveUsedSpace, Mode=OneWay}" />
                                <TextBlock Text="{x:Bind DriveFreeSpace, Mode=OneWay}" Foreground="#94A3B8"/>
                            </StackPanel>

                            <!-- Temperature + Health -->
                            <StackPanel Grid.Row="1" Grid.Column="1">
                                <TextBlock Text="{x:Bind DriveTemperature, Mode=OneWay}"
                           Foreground="{ThemeResource SystemAccentColor}"
                           FontWeight="Bold"/>
                                <TextBlock Text="{x:Bind DriveHealth, Mode=OneWay}" Foreground="#94A3B8"/>
                            </StackPanel>

                            <!-- Read / Write -->
                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="{x:Bind DriveReadRate, Mode=OneWay}" />
                                <TextBlock Text="{x:Bind DriveWriteRate, Mode=OneWay}" />
                            </StackPanel>

                            <!-- Life + Power-On -->
                            <StackPanel Grid.Row="2" Grid.Column="1">
                                <TextBlock Text="{x:Bind DriveLifeText, Mode=OneWay}" Foreground="#94A3B8"/>
                                <TextBlock Text="{x:Bind PowerOnHours, Mode=OneWay}" Foreground="#94A3B8"/>
                            </StackPanel>

                        </Grid>
                    </StackPanel>
                </Border>

                <!-- RIGHT SIDE STACK -->
                <Grid Grid.Column="1" RowSpacing="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- NETWORK -->
                    <Border Grid.Row="1" CornerRadius="12" Background="{ThemeResource LayerFillColorDefaultBrush }" Padding="16" >
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Foreground="Gray" Glyph="&#xE774;" FontSize="16"/>
                                <TextBlock Foreground="Gray" Text="NETWORK" FontWeight="SemiBold"/>
                            </StackPanel>

                            <ComboBox 
                            x:Name="NetworkAdapterComboBox"
                            ItemsSource="{x:Bind AvailableNetworkAdapters, Mode=OneWay}"
                            SelectedIndex="{x:Bind SelectedNetworkAdapterIndex, Mode=TwoWay}"
                            PlaceholderText="Select Network Adapter..."
                            Margin="0,12,0,12"/>

                            <TextBlock Text="{x:Bind NetworkAdapterName, Mode=OneWay}" FontWeight="SemiBold" FontSize="14" Margin="0,8,0,4"/>
                            <TextBlock Text="{x:Bind NetworkStatus, Mode=OneWay}" Foreground="#94A3B8" FontSize="12"/>

                            <Grid ColumnSpacing="8" RowSpacing="8" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Column="0" Grid.Row="0">
                                    <TextBlock Text="Download" Foreground="#94A3B8" FontSize="11"/>
                                    <TextBlock Text="{x:Bind NetworkDownloadSpeed, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Grid.Row="0">
                                    <TextBlock Text="Upload" Foreground="#94A3B8" FontSize="11"/>
                                    <TextBlock Text="{x:Bind NetworkUploadSpeed, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>

                                <TextBlock Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Text="{x:Bind NetworkLatency, Mode=OneWay}" Foreground="#94A3B8" FontSize="11"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- PROCESSES -->
                    <Border Grid.Row="0" CornerRadius="12" Background="{ThemeResource LayerFillColorDefaultBrush }" Padding="16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Foreground="Gray" Glyph="&#xEEA0;" FontSize="16"/>
                                <TextBlock Foreground="Gray" Text="TOP PROCESSES" FontWeight="SemiBold"/>
                            </StackPanel>

                            <ListView ItemsSource="{x:Bind TopProcesses, Mode=OneWay}"
                                  SelectionMode="None"
                                  Margin="0,12,0,0"
                                  MaxHeight="120">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:ProcessInfo">
                                        <Grid ColumnSpacing="8" Padding="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}" 
                                                       FontSize="13" 
                                                       FontWeight="SemiBold"
                                                       Foreground="White"/>
                                                <TextBlock Text="{x:Bind ProcessId, Mode=OneWay}" 
                                                       FontSize="11" 
                                                       Foreground="#94A3B8"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1"
                                                   Text="{x:Bind CpuUsageText, Mode=OneWay}" 
                                                   FontSize="12" 
                                                   Foreground="{ThemeResource SystemAccentColor}"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Right"/>

                                            <TextBlock Grid.Column="2"
                                                   Text="{x:Bind MemoryUsageText, Mode=OneWay}" 
                                                   FontSize="12" 
                                                   Foreground="#94A3B8"
                                                   TextAlignment="Right"
                                                   Margin="12,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                </Grid>
            </Grid>

        </Grid>

    </ScrollViewer>
    
   
    
</Page>

