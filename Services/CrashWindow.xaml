<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CoreStrike.CrashWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="CrashWindow">

    <Grid Padding="20" MinHeight="600" VerticalAlignment="Top" MinWidth="500" MaxHeight="600" MaxWidth="500">

        <StackPanel Spacing="15">

            <TextBlock
             FontSize="22"
             FontWeight="Bold"
             Text="⚠ WinDynamicIsland Crashed" />

            <TextBlock
             TextWrapping="Wrap"
             Text="An unexpected error occurred. A crash report has been saved and will be uploaded automatically the next time the application starts." />




            <Border BorderBrush="Gray" BorderThickness="1" Padding="20" >

                <ScrollViewer>




                    <TextBlock
   x:Name="ErrorText"
   FontFamily="Consolas"
   TextWrapping="Wrap"/>

                </ScrollViewer>
            </Border>


            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">

                <Button
                 
                 x:Name="SendReportButton"
                 Content="Send Report"
                 Click="Restart_Click"/>

                <Button
                 x:Name="CloseButton"
                 Content="Close"
                 Click="Close_Click"/>

            </StackPanel>

        </StackPanel>

    </Grid>
</Window>
