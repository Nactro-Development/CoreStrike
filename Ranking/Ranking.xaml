<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CoreStrike.Ranking.Ranking"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16">

            <TextBlock Text="Global Rankings" FontSize="22" FontWeight="SemiBold"/>

            <!-- TOP 3 PODIUM -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- #1 Gold -->
                <Border Grid.Column="0" Margin="0,0,5,0" Padding="14" CornerRadius="10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{StaticResource SystemAccentColor}" BorderThickness="1.5">
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <StackPanel Spacing="4" MinWidth="70">
                            <TextBlock Text="#1" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock x:Name="FirstPlaceText" FontSize="13" Opacity="0.7" Margin="0,4,0,0"/>
                            <TextBlock x:Name="FirstScoreText" FontSize="20" FontWeight="SemiBold"
                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xEDA2;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.6"/>
                                <TextBlock x:Name="FirstStorageText" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE950;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.6"/>
                                <TextBlock x:Name="FirstCPUText" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.6"/>
                                <TextBlock x:Name="FirstGPUText" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE770;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.6"/>
                                <TextBlock x:Name="FirstOSText" FontSize="11" Opacity="0.7" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xEEA0;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.6"/>
                                <TextBlock x:Name="FirstMemoryText" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.6"/>
                                <TextBlock x:Name="FirstMotherboardText" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- #2 -->
                <Border Grid.Column="1" Margin="5,0,5,0" Padding="14" CornerRadius="10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0.5">
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <StackPanel Spacing="4" MinWidth="70">
                            <TextBlock Text="#2" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock x:Name="SecondPlaceText" FontSize="13" Opacity="0.7" Margin="0,4,0,0"/>
                            <TextBlock x:Name="SecondScoreText" FontSize="20" FontWeight="SemiBold"
                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xEDA2;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.6"/>
                                <TextBlock x:Name="SecondStorageText" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE950;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.6"/>
                                <TextBlock x:Name="SecondCPUText" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.6"/>
                                <TextBlock x:Name="SecondGPUText" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE770;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.6"/>
                                <TextBlock x:Name="SecondOSText" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xEEA0;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.6"/>
                                <TextBlock x:Name="SecondMemoryText" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.6"/>
                                <TextBlock x:Name="SecondMotherboardText" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- #3 -->
                <Border Grid.Column="2" Margin="5,0,0,0" Padding="14" CornerRadius="10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0.5">
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <StackPanel Spacing="4" MinWidth="70">
                            <TextBlock Text="#3" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock x:Name="ThirdPlaceText" FontSize="13" Opacity="0.7" Margin="0,4,0,0"/>
                            <TextBlock x:Name="ThirdScoreText" FontSize="20" FontWeight="SemiBold"
                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xEDA2;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.6"/>
                                <TextBlock x:Name="ThirdStorageText" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE950;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.6"/>
                                <TextBlock x:Name="ThirdCPUText" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.6"/>
                                <TextBlock x:Name="ThirdGPUText" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE770;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.6"/>
                                <TextBlock x:Name="ThirdOSText" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xEEA0;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.6"/>
                                <TextBlock x:Name="ThirdMemoryText" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.6"/>
                                <TextBlock x:Name="ThirdMotherboardText" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </Grid>

            <!-- YOUR POSITION -->
            <Border Padding="16" CornerRadius="10"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Your position" FontSize="12" Opacity="0.6"/>
                    <TextBlock x:Name="MyRankText" FontSize="26" FontWeight="SemiBold"/>
                    <ProgressBar x:Name="RankProgressBar" Height="8" CornerRadius="4"/>
                </StackPanel>
            </Border>

            <!-- LEADERBOARD -->
            <Border CornerRadius="10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0.5">
                <ListView x:Name="RankingListView" SelectionMode="None">

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="MinHeight" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.Header>
                        <Grid Padding="12,10"
                              Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Rank" FontSize="12" FontWeight="SemiBold" Opacity="0.6" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Country" FontSize="12" FontWeight="SemiBold" Opacity="0.6" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="User" FontSize="12" FontWeight="SemiBold" Opacity="0.6"/>
                            <TextBlock Grid.Column="3" Text="PC" FontSize="12" FontWeight="SemiBold" Opacity="0.6"/>
                            <TextBlock Grid.Column="4" Text="Score" FontSize="12" FontWeight="SemiBold" Opacity="0.6" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="5" Text="Grade" FontSize="12" FontWeight="SemiBold" Opacity="0.6" HorizontalAlignment="Center"/>
                        </Grid>
                    </ListView.Header>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,1,0,0">
                                <Grid Height="44" Padding="12,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Rank}"
                                               FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Image Grid.Column="1" Source="{Binding CountryFlagImage}"
                                           Width="22" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding UserName}"
                                               FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="3" Text="{Binding PcModel}"
                                               FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Opacity="0.8"/>
                                    <TextBlock Grid.Column="4" Text="{Binding OverallScore}"
                                               FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="{Binding Grade}"
                                               FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>

                </ListView>
            </Border>

        </StackPanel>
    </ScrollViewer>

</Page>