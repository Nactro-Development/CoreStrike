
<Window
    x:Class="CoreStrike.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CoreStrike"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="CoreStrike">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>

        <NavigationView BorderThickness="0"  BorderBrush="Transparent" Background="Transparent"
 SelectionChanged="NavView_SelectionChanged">

            <NavigationView.Resources>

                <!-- LEFT PANE -->
                <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground"
                         Color="Transparent"/>

                <!-- RIGHT CONTENT AREA (THIS is what you want) -->
                <SolidColorBrush x:Key="NavigationViewContentBackground"
                         Color="Transparent"/>

                <!-- Remove content border -->
                <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>


                
                <!-- Sometimes needed (WinUI quirks) -->
                <SolidColorBrush x:Key="NavigationViewTopPaneBackground"
                         Color="Transparent"/>



            </NavigationView.Resources>


            <NavigationView.MenuItems>
                <NavigationViewItem IsSelected="True" Content="DashBord" Tag="DashBord">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xECA5;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="BenchMarks" Tag="BenchMarks">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Ranking" Tag="Ranking">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Donate" Tag="SamplePage4" Icon="Contact" />
            </NavigationView.FooterMenuItems>


            <Frame BorderThickness="0" Background="Transparent" x:Name="contentFrame"/>
        </NavigationView>

    </Grid>
</Window>
